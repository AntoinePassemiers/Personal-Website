---
const { folder, filename, alt } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const base = (BASE !== "/") ? new URL(BASE, folder).pathname : folder;
---

<picture>
  <source srcset={`${base}/dark/${filename}`} media="(prefers-color-scheme: dark)" />
  <source srcset={`${base}/light/${filename}`} media="(prefers-color-scheme: light)" />
  <img src={`${base}/dark/${filename}`} alt={alt} />
</picture>