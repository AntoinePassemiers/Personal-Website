---
interface Props {
  level: number;
  lang?: string;
}

const { level, lang = "en" } = Astro.props;

const difficultyLabel = lang === "en" ? "Difficulty" : "Difficulté";
const labels =
  lang === "en"
    ? ["Beginner", "Easy", "Intermediate", "Advanced", "Expert"]
    : ["Débutant", "Facile", "Intermédiaire", "Avancé", "Expert"];

const colors = [
  "#4caf50", // Beginner (green)
  "#8bc34a", // Easy
  "#ffc107", // Intermediate (yellow)
  "#ff9800", // Advanced (orange)
  "#f44336", // Expert (red)
];

const color = colors[Math.max(0, Math.min(level - 1, colors.length - 1))];
---

<div class="difficulty" style={`--difficulty-color: ${color}`}>
  <span>{difficultyLabel}:</span>

  <div class="gauge">
    {[1, 2, 3, 4, 5].map((i) => (
      <span class={i <= level ? "active" : ""}>●</span>
    ))}
  </div>

  <span>{labels[level - 1]}</span>
</div>

<style>
  .difficulty {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .gauge {
    display: flex;
    gap: 0.2rem;
  }

  .gauge span {
    color: #ccc;
  }

  .gauge span.active {
    color: var(--difficulty-color);
  }
</style>