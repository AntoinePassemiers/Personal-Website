---
interface Props {
  level: number;
  lang?: string;
}

const { level, lang = "en" } = Astro.props;

const labels =
  lang === "en"
    ? ["Beginner", "Easy", "Intermediate", "Advanced", "Expert"]
    : ["Débutant", "Facile", "Intermédiaire", "Avancé", "Expert"];
---

<div class="difficulty">
  <span>Difficulty:</span>

  <div class="gauge">
    {[1, 2, 3, 4, 5].map((i) => (
      <span class={i <= level ? "active" : ""}>●</span>
    ))}
  </div>

  <span>{labels[level - 1]}</span>
</div>

<style>
  .difficulty {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .gauge {
    display: flex;
    gap: 0.2rem;
  }

  .gauge span {
    color: #ccc;
  }

  .gauge span.active {
    color: #4caf50;
  }
</style>