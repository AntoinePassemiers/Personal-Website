---
import { joinPaths } from '../utils/url-utils.js';

const {
  lang = 'en',
  alternateHref = null
} = Astro.props;

const base = import.meta.env.BASE_URL;
const withBase = (path) => {
  if (base !== '/' && path.startsWith(base)) return path;
  //return `${base}${path.replace(/^\//, '')}`;
  return joinPaths(base, path.replace(/^\//, ''));
};
const currentPath = Astro.url.pathname;
const normalizedLang = lang === 'fr' ? 'fr' : 'en';
const otherLang = normalizedLang === 'en' ? 'fr' : 'en';
const labels = {
  en: {
    home: 'Home',
    blog: 'Blog',
    //game: 'Game',
    currently: 'EN',
    switchTo: 'FR'
  },
  fr: {
    home: 'Accueil',
    blog: 'Blog',
    //game: 'Jeu',
    currently: 'FR',
    switchTo: 'EN'
  }
};
const t = labels[normalizedLang];
const links = [
  { href: `/${normalizedLang}/`, label: t.home },
  { href: `/blog/${normalizedLang}/`, label: t.blog },
  //{ href: `/game/${normalizedLang}/`, label: t.game }
];
const fallbackAlternate = currentPath.replace(new RegExp(`/${normalizedLang}/?$`), `/${otherLang}/`);
const switchHref = alternateHref ?? fallbackAlternate;
---
<header class="site-header">

  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      const root = document.documentElement;
      const btn = document.querySelector('[data-theme-toggle]');

      if (!btn) return;

      function updateThemeImages() {
        const isLight = root.classList.contains('light');

        document.querySelectorAll('[data-theme-image]').forEach((img) => {
          img.src = isLight ? img.dataset.light : img.dataset.dark;
        });
      }

      function updateButton() {
        btn.textContent = root.classList.contains('light')
          ? '☀️'
          : '🌙';
      }

      updateButton();
      updateThemeImages();

      btn.addEventListener('click', () => {
        const isLight = !root.classList.contains('light');

        root.classList.toggle('light', isLight);

        localStorage.setItem(
          'theme',
          isLight ? 'light' : 'dark'
        );

        updateButton();
        updateThemeImages();
      });
    });
  </script>

  <nav class="container nav" aria-label="Main navigation">
    <a class="brand" href={withBase(`/${normalizedLang}/`)}>
      <span class="brand-mark" aria-hidden="true">✦</span>
      <span>AP ²</span>
    </a>
    <div class="nav-links">
      {links.map((link) => {
        const href = withBase(link.href);
        const isCurrent = currentPath === new URL(href, Astro.url).pathname || currentPath.endsWith(link.href);
        return <a href={href} aria-current={isCurrent ? 'page' : undefined}>{link.label}</a>;
      })}
      <div class="toggle-group">
        <button
          class="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          data-theme-toggle
        >
          🌙
        </button>
        <a
          class="language-toggle"
          href={withBase(switchHref)}
          data-language-toggle
          data-language={otherLang}
          aria-label={`Switch language to ${otherLang.toUpperCase()}`}
        >
          {t.currently}
        </a>
      </div>
    </div>
  </nav>
</header>
