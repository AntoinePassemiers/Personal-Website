---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mini Scrabble"
  description="A minimal Scrabble-like game built with Phaser."
  lang="en"
>
  <section class="game-shell">
    <h1>Mini Scrabble</h1>
    <p>Drag tiles onto the board, then submit your word.</p>

    <div id="phaser-game" class="phaser-game"></div>
  </section>

  <div id="scrabble-layout" class="scrabble-layout">
    <div id="phaser-game" class="phaser-game"></div>
  </div>

  <script>
    import { startScrabble } from '../../game/game.js';

    window.addEventListener('DOMContentLoaded', () => {
      const game = startScrabble('phaser-game');

      document.addEventListener('keydown', (event) => {
        if (event.key === '*') {
          game.scale.toggleFullscreen();
        }
      });
    });
  </script>
</BaseLayout>