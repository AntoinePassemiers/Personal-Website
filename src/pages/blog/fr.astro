---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTagClass } from '../../utils/tags.js';

const modules = import.meta.glob('./**/*.md', { eager: true });

const posts = Object.entries(modules)
  .map(([path, module]) => {
    const frontmatter = module.frontmatter;
    const slug = path.replace('./', '').replace('/index.md', '').replace('.md', '');

    return {
      title: frontmatter.title,
      description: frontmatter.description,
      date: frontmatter.date,
      lang: frontmatter.lang ?? 'en',
      tag: frontmatter.tag ?? 'Général',
      href: `${import.meta.env.BASE_URL}blog/${slug}/`
    };
  })
  .filter((post) => post.lang === 'fr')
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const formatDate = (date) =>
  new Intl.DateTimeFormat('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(new Date(date));

const tags = [...new Set(posts.map((post) => post.tag))].sort();
---

<script>
  const selectedTags = new Set();

  const filterButtons = document.querySelectorAll('[data-tag-filter]');
  const articles = document.querySelectorAll('[data-post-tags]');

  function updateFilters() {
    articles.forEach((article) => {
      const tags = article.dataset.postTags
        .split(',')
        .map((tag) => tag.trim());

      const shouldShow =
        selectedTags.size === 0 ||
        tags.some((tag) => selectedTags.has(tag));

      article.hidden = !shouldShow;
    });

    filterButtons.forEach((button) => {
      const tag = button.dataset.tagFilter;
      const isSelected = selectedTags.has(tag);

      button.classList.toggle('is-selected', isSelected);
      button.classList.toggle('is-muted', selectedTags.size > 0 && !isSelected);
      button.setAttribute('aria-pressed', String(isSelected));
    });
  }

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const tag = button.dataset.tagFilter;

      if (selectedTags.has(tag)) {
        selectedTags.delete(tag);
      } else {
        selectedTags.add(tag);
      }

      updateFilters();
    });
  });
</script>

<BaseLayout title="Blog · Astro Pages" description="Tous les articles français du blog Astro Pages." lang="fr" alternateHref="/blog/en/">
  <section class="container page-hero">
    <p class="eyebrow">Blog</p>
    <h1>Tous les articles</h1>
    <p class="lede">
      Pour l'instant, je parle principalement de Machine Learning. Revenez plus tard pour plus de contenu.
    </p>

    <div class="tag-cloud" aria-label="Tags disponibles">
      {tags.map((tag) => (
        <button
          class={`${getTagClass(tag)} tag-filter`}
          type="button"
          data-tag-filter={tag}
          aria-pressed="false"
        >
          {tag}
        </button>
      ))}
    </div>
  </section>

  <section class="container article-list" aria-label="Articles du blog">
    {posts.map((post) => (
      <a class="article-row card" href={post.href} data-post-tags={post.tag}>
        <div>
          <div class="article-meta">
            <time datetime={new Date(post.date).toISOString()}>
              {formatDate(post.date)}
            </time>
          </div>
          <h2>{post.title}</h2>
          <p>{post.description}</p>
        </div>

        <span class={getTagClass(post.tag)}>{post.tag}</span>
      </a>
    ))}
  </section>
</BaseLayout>
