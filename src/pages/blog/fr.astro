---
import BaseLayout from '../../layouts/BaseLayout.astro';

const modules = import.meta.glob('./**/*.md', { eager: true });
const posts = Object.entries(modules)
  .map(([path, module]) => {
    const frontmatter = module.frontmatter;
    const slug = path.replace('./', '').replace('/index.md', '').replace('.md', '');
    return {
      title: frontmatter.title,
      description: frontmatter.description,
      date: frontmatter.date,
      lang: frontmatter.lang ?? 'en',
      tag: frontmatter.tag ?? 'Général',
      href: `${import.meta.env.BASE_URL}blog/${slug}/`
    };
  })
  .filter((post) => post.lang === 'fr')
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const formatDate = (date) =>
  new Intl.DateTimeFormat('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(new Date(date));
const tags = [...new Set(posts.map((post) => post.tag))].sort();
---
<BaseLayout title="Blog · Astro Pages" description="Tous les articles français du blog Astro Pages." lang="fr" alternateHref="/blog/en/">
  <section class="container page-hero">
    <p class="eyebrow">Blog</p>
    <h1>Tous les articles</h1>
    <p class="lede">
      Notes techniques, exemples et expérimentations. Chaque article possède un tag pour faciliter ensuite le filtrage, la recherche ou les collections.
    </p>
    <div class="tag-cloud" aria-label="Tags disponibles">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </section>

  <section class="container article-list" aria-label="Articles du blog">
    {posts.map((post) => (
      <a class="article-row card" href={post.href}>
        <div>
          <div class="article-meta">
            <time datetime={new Date(post.date).toISOString()}>
              {formatDate(post.date)}
            </time>
          </div>
          <h2>{post.title}</h2>
          <p>{post.description}</p>
        </div>
        <span class="tag">{post.tag}</span>
      </a>
    ))}
  </section>
</BaseLayout>
