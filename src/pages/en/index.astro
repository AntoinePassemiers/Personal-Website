---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { joinPaths } from '../../utils/url-utils.js';

const base = import.meta.env.BASE_URL;
const withBase = (path) => joinPaths(base, path.replace(/^\//, ''));
---
<BaseLayout title="AP ²" lang="en" alternateHref="/fr/">
  <section class="container hero">
    <div>
      <p class="eyebrow">Antoine Passemiers' Astro Pages</p>
      <h1>AP ²</h1>
      <p class="lede">
        Here, I share things that are close to my heart, such as interesting findings, summaries of technical books, or remnants of old projects I created during my studies or in my free time.
      </p>
      <div class="button-row">
        <a class="button" href={withBase('/blog/en/')}>Read blog posts</a>
        <!-- <a class="button secondary" href={withBase('/game/en/')}>Play tiny game</a> -->
      </div>
    </div>
    <!--
    <aside class="card hero-card stack">
      <p class="eyebrow">Architecture</p>
      <h3>One navbar. Many pages.</h3>
      <p class="post-meta">
        `Navbar.astro`, `Footer.astro`, `BaseLayout.astro`, and `PostLayout.astro`
        are authored once and reused everywhere at build time.
      </p>
    </aside>
    -->
  </section>

  <!--
  <section class="container">
    <p class="eyebrow">Featured</p>
    <div class="grid">
      <a class="card post-card" href={withBase('/blog/code-examples/en/')}>
        <p class="post-meta">Technical writing</p>
