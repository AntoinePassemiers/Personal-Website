      </a>
      <a class="card post-card" href={withBase('/blog/en/')}>
        <p class="post-meta">Blog</p>
        <h3>All articles</h3>
        <p class="post-meta">A language-aware article list with tags.</p>
      </a>
      <a class="card post-card" href={withBase('/game/en/')}>
        <p class="post-meta">Game</p>
        <h3>Client-side canvas</h3>
        <p class="post-meta">A tiny browser game served as static files.</p>
      </a>
    </div>
  </section>
