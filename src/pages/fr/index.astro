---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { joinPaths } from '../../utils/url-utils.js';

const base = import.meta.env.BASE_URL;
const withBase = (path) => joinPaths(base, path.replace(/^\//, ''));
---
<BaseLayout title="AP ²" lang="fr" alternateHref="/en/">
  <section class="container hero">
    <div>
      <p class="eyebrow">Antoine Passemiers' Astro Pages</p>
      <h1>AP ²</h1>
      <p class="lede">
        Je partage ici ce qui me tient à coeur, tel que des trouvailles intéressantes, des résumés de livres techniques, ou des relicats de vieux projets créés durant mes études ou mon temps libre.
      </p>
      <div class="button-row">
        <a class="button" href={withBase('/blog/fr/')}>Lire mes posts</a>
        <!-- <a class="button secondary" href={withBase('/game/fr/')}>Jouer au mini-jeu</a> -->
      </div>
    </div>
