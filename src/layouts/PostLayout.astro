---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const lang = frontmatter.lang === 'fr' ? 'fr' : 'en';
const otherLang = lang === 'en' ? 'fr' : 'en';
const alternateHref = Astro.url.pathname.replace(new RegExp(`/${lang}/?$`), `/${otherLang}/`);
const author = frontmatter.author;
const formattedDate = frontmatter.date
  ? new Intl.DateTimeFormat(lang === 'fr' ? 'fr-FR' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    }).format(new Date(frontmatter.date))
  : null;
---
<BaseLayout title={`${frontmatter.title} · Astro Pages Blog`} description={frontmatter.description} lang={lang} alternateHref={alternateHref}>
  <article class="prose">
    <h1>{frontmatter.title}</h1>
    <p class="lede">{frontmatter.description}</p>
    <div class="post-meta">
      {formattedDate && <time datetime={new Date(frontmatter.date).toISOString()}>{formattedDate}</time>}   ·   
      {author && <span>{author}</span>}
    </div>
    <br>
    {frontmatter.tag && <span class="tag">{frontmatter.tag}</span>}
    <slot />
  </article>
</BaseLayout>
